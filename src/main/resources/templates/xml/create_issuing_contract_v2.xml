            <wsin:ProductIdentifier th:text="${productIdentifier}">250314000000000000000590</wsin:ProductIdentifier>
            <wsin:ApplRegNumber th:text="${applRegNumber}">REQ-001</wsin:ApplRegNumber>
            <wsin:InObject>
                <wsin:Branch th:text="${branch}">0101</wsin:Branch>
                <wsin:InstitutionCode th:text="${insCode}">0001</wsin:InstitutionCode>
                <wsin:Currency th:text="${currency}">810</wsin:Currency>
